# MongoDB Connection String
MONGO_URI=mongodb://localhost:27017/academic_review

# JWT Secret Key (change this to a strong secret in production)
JWT_SECRET=your_jwt_secret_key_here_please_change_this_to_a_strong_secret_in_production

# Server Port
PORT=5000

# Cloudinary Configuration (optional for PDF uploads)
# Sign up at https://cloudinary.com for free account
# CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME
# Or set individually:
# CLOUDINARY_CLOUD_NAME=your_cloud_name
# CLOUDINARY_API_KEY=your_api_key
# CLOUDINARY_API_SECRET=your_api_secret
